---
// Each member's ceramic maker's mark — the stamp pressed into the foot of a pot.
const { kind } = Astro.props;
---
{kind === 'spiral' && (
<svg viewBox="0 0 40 40" aria-hidden="true" class="draw">
  <path pathLength="1" class="s" d="M20 20 q3 -1 3 3 q0 5 -6 5 q-8 0 -8 -9 q0 -11 12 -11 q13 0 13 13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
</svg>
)}
{kind === 'strata' && (
<svg viewBox="0 0 40 40" aria-hidden="true" class="draw">
  <path pathLength="1" class="s" d="M8 13 q12 -4 24 0" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
  <path pathLength="1" class="s" d="M8 21 q12 3 24 0" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
  <path pathLength="1" class="s" d="M11 29 q9 -3 18 0" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
</svg>
)}
{kind === 'moonwave' && (
<svg viewBox="0 0 40 40" aria-hidden="true" class="draw">
  <path pathLength="1" class="s" d="M7 27 q6 -6 13 -1 q7 5 13 -1" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
  <path pathLength="1" class="s" d="M17 13 a6 6 0 1 1 5 8" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
</svg>
)}
{kind === 'kilnbrick' && (
<svg viewBox="0 0 40 40" aria-hidden="true" class="draw">
  <path pathLength="1" class="s" d="M11 11 q9 -3 18 1 q2 9 -1 17 q-9 3 -17 -1 q-3 -8 0 -17" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
  <path pathLength="1" class="s" d="M13 24 l14 -9" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
</svg>
)}
